{
  "name": "@discordanalytics/oceanic",
  "version": "2.8.2",
  "description": "Oceanic package for working with Discord Analytics",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "author": "Discord Analytics",
  "homepage": "https://discordanalytics.xyz",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DiscordAnalytics/node-package.git"
  },
  "bugs": {
    "url": "https://github.com/DiscordAnalytics/node-package/issues"
  },
  "scripts": {
    "prebuild": "pnpm --filter @discordanalytics/core build",
    "build": "tsdown"
  },
  "dependencies": {
    "@discordanalytics/core": "workspace:*"
  },
  "devDependencies": {
    "oceanic.js": "^1.14.0",
    "tsdown": "*",
    "typescript": "*"
  },
  "peerDependencies": {
    "oceanic.js": ">=1.14.x"
  }
}
