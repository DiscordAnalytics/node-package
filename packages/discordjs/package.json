{
  "name": "@discordanalytics/discordjs",
  "version": "2.9.2",
  "description": "Discord.js package for working with Discord Analytics",
  "license": "LGPL-2.1-only",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "author": "Discord Analytics",
  "homepage": "https://discordanalytics.xyz",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DiscordAnalytics/node-package.git"
  },
  "bugs": {
    "url": "https://github.com/DiscordAnalytics/node-package/issues"
  },
  "scripts": {
    "prebuild": "pnpm --filter @discordanalytics/core build",
    "prepack": "pnpm run build",
    "build": "tsdown"
  },
  "dependencies": {
    "@discordanalytics/core": "2.10.0"
  },
  "devDependencies": {
    "discord.js": "14.27.0",
    "tsdown": "0.22.12",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "discord.js": "14.x"
  }
}
